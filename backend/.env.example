# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:
MONGO_URI=mongodb://127.0.0.1:27017/smart_campus_iot
# Production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smart_campus_iot

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES=7d

# ─── IoT Device Auth ──────────────────────────────────────────────────────────
# All edge devices must send this key in the X-Device-Key header
DEVICE_INGEST_KEY=replace_with_secure_random_key

# ─── AWS S3 (for report storage) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=smart-campus-reports

# ─── Firebase (push notifications) ───────────────────────────────────────────
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
